{
  "version": "6.1",
  "description": "V6.1 总控中心版 - 整合EV过滤+订单生命周期管理+总控中心(自我检查/自我修复/自我优化)",
  "initial_cash": 100000,
  
  "ev_filter": {
    "enabled": true,
    "min_ev": 0.00035,
    "confidence_threshold": 0.6,
    "risk_reward_ratio": 2.0,
    "description": "预期价值过滤模块，过滤负期望交易，提升胜率和夏普比率"
  },
  
  "order_lifecycle": {
    "enabled": true,
    "default_ttl_ms": 800,
    "dedup_ttl_seconds": 300,
    "enable_auto_cancel": true,
    "description": "订单生命周期管理，实现幂等性控制和超时撤单"
  },
  
  "scan": {
    "symbols": ["BTCUSDT", "ETHUSDT", "SOLUSDT", "BNBUSDT"],
    "timeframes": ["5m", "15m", "1h", "4h"],
    "enabled_strategies": ["TREND", "MEAN_REVERSION", "BREAKOUT", "PAIRS_TRADING"]
  },
  
  "analysis": {
    "weights": {
      "technical": 0.35,
      "fundamental": 0.15,
      "sentiment": 0.15,
      "risk": 0.15,
      "prediction": 0.20
    }
  },
  
  "decision": {
    "signal_threshold": 0.60,
    "min_expected_value": 0.00035,
    "min_confidence": 0.55,
    "strategies": ["ma_trend", "rsi_mean_revert", "orderflow_break", "volatility_break"],
    "linucb_enabled": true,
    "ev_filter_enabled": true
  },
  
  "multi_strategy": {
    "signal_threshold": 0.6,
    "conflict_threshold": 0.2,
    "ma_trend": {
      "initial_weight": 0.3,
      "fast_window": 20,
      "slow_window": 60,
      "consecutive_loss_limit": 3,
      "cooldown_seconds": 1800
    },
    "rsi_mean_revert": {
      "initial_weight": 0.2,
      "rsi_oversold": 30,
      "rsi_overbought": 70,
      "consecutive_loss_limit": 2,
      "cooldown_seconds": 1200
    },
    "orderflow_break": {
      "initial_weight": 0.3,
      "imbalance_threshold": 0.3,
      "cvd_trend_threshold": 0.2,
      "consecutive_loss_limit": 2,
      "cooldown_seconds": 900
    },
    "volatility_break": {
      "initial_weight": 0.2,
      "atr_multiplier": 1.5,
      "consecutive_loss_limit": 3,
      "cooldown_seconds": 1800
    }
  },
  
  "risk": {
    "max_position_pct": 0.10,
    "consecutive_loss_limit": 5,
    "max_daily_loss_pct": 0.025,
    "max_orders_per_minute": 30,
    "max_drawdown": 0.08,
    "correlation_limit": 3,
    "min_liquidity_usdt": 10000,
    "circuit_breaker": {
      "soft_breaker_threshold": 0.05,
      "hard_breaker_threshold": 0.10,
      "soft_cooldown_seconds": 600,
      "hard_cooldown_seconds": 3600
    },
    "trailing_stop": {
      "activation_pct": 0.005,
      "trail_pct": 0.003
    },
    "time_stop": {
      "max_holding_seconds": 120,
      "min_profit_pct": 0.0005
    },
    "volatility_breaker": {
      "max_volatility_pct": 0.02
    },
    "extreme_price_move": {
      "max_move_pct": 0.01
    },
    "gap_risk": {
      "max_gap_pct": 0.015
    },
    "adverse_selection": {
      "max_slippage_pct": 0.002
    }
  },
  
  "execution": {
    "order_type": "LIMIT",
    "time_in_force": "GTC",
    "default_ttl_ms": 800,
    "slippage_limit": 0.001,
    "taker_fee": 0.0004,
    "maker_fee": 0.0002
  },
  
  "close": {
    "take_profit_levels": [0.8, 1.0, 1.5],
    "trailing_stop_activation": 0.005,
    "trailing_stop_trail": 0.003
  },
  
  "optimization": {
    "enabled": true,
    "weekly_schedule": "Sunday 03:00",
    "parameters": ["signal_threshold", "tp_atr_multiple", "sl_atr_multiple", "order_frequency_limit"]
  },
  
  "controller": {
    "health_check_interval": 30,
    "repair_interval": 60,
    "max_consecutive_failures": 3,
    "max_repair_retries": 3,
    "tune_interval": 300,
    "description": "V6.1总控中心配置：自我检查/自我修复/自我优化"
  },
  
  "performance_targets": {
    "win_rate": 0.63,
    "sharpe_ratio": 1.2,
    "max_drawdown": 0.10,
    "daily_trades": 150,
    "linucb_latency_us": 50
  }
}
