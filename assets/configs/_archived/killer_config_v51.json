{
  "version": "V5.1",
  "description": "V5.1基础设施优化版 - P0/P1级核心优化",
  "priority": {
    "P0": [
      "数据质量验证（time模块修复、时间戳标准化）",
      "代码稳定性问题修复"
    ],
    "P1": [
      "LSTM训练数据收集",
      "LinUCB冷启动优化",
      "市场状态识别滞后优化"
    ]
  },
  "data_quality_validator": {
    "enabled": true,
    "min_timestamp": 1609459200000,
    "price_change_threshold": 0.2,
    "outlier_std_multiplier": 3.0,
    "required_fields": [
      "timestamp",
      "open",
      "high",
      "low",
      "close",
      "volume"
    ],
    "auto_clean": true,
    "strict_mode": false
  },
  "lstm_data_collector": {
    "enabled": true,
    "sequence_length": 60,
    "prediction_horizon": 10,
    "feature_count": 5,
    "timeframes": ["1m", "5m", "15m", "1h"],
    "min_samples": 10000,
    "max_samples": 100000,
    "db_path": "state/lstm_training_data.db",
    "incremental_training": true,
    "model_performance_monitoring": true
  },
  "linucb_cold_start": {
    "enabled": true,
    "feature_dim": 14,
    "alpha": 1.0,
    "epsilon": 0.1,
    "use_bayesian_prior": true,
    "pretrain_required": true,
    "backtest_data_required": true,
    "min_backtest_trades": 100,
    "model_path": "state/linucb_cold_start_model.pkl",
    "mode": "epsilon_greedy"
  },
  "market_regime_optimizer": {
    "enabled": true,
    "adx_threshold_strong": 30,
    "adx_threshold_weak": 20,
    "rsi_overbought": 70,
    "rsi_oversold": 30,
    "volatility_threshold": 0.02,
    "confidence_threshold": 0.6,
    "confidence_adaptive": true,
    "early_warning_threshold": 0.75,
    "min_stability_periods": 1,
    "orderbook_slope_weight": 0.3,
    "volume_delta_weight": 0.2,
    "probability_based": true,
    "early_warning": true
  },
  "system_fixes": {
    "time_module_import": {
      "enabled": true,
      "modules_to_fix": [
        "run.py",
        "state_manager.py",
        "async_event_engine.py",
        "high_fidelity_execution.py",
        "profit_taking_optimizer.py"
      ]
    },
    "data_validation": {
      "enabled": true,
      "timestamp_normalization": true,
      "outlier_detection": true,
      "data_completeness_check": true
    }
  },
  "training_pipeline": {
    "data_collection": {
      "source": "lstm_data_collector",
      "auto_collect": true,
      "collect_interval": 3600,
      "min_samples_for_training": 10000
    },
    "model_training": {
      "source": "lstm_dynamic_profit",
      "auto_train": false,
      "train_interval": 86400,
      "validation_split": 0.2
    },
    "linucb_pretrain": {
      "source": "linucb_cold_start",
      "auto_pretrain": true,
      "backtest_data_path": "state/backtest_results.json",
      "market_states_path": "state/market_states.json"
    }
  },
  "monitoring": {
    "data_quality": {
      "enabled": true,
      "check_interval": 600,
      "alert_threshold": 0.9
    },
    "model_performance": {
      "enabled": true,
      "check_interval": 3600,
      "performance_decay_threshold": 0.8
    },
    "regime_prediction": {
      "enabled": true,
      "check_interval": 60,
      "confidence_alert": 0.5
    }
  },
  "performance_metrics": {
    "expected_improvements": {
      "system_stability": "100% (time模块修复)",
      "data_quality": "90%+ (通过验证)",
      "lstm_prediction_accuracy": "+20%-30%",
      "linucb_convergence_speed": "+50% (从第1笔交易开始)",
      "market_response_latency": "-50% (从3周期降至1周期)",
      "market_adaptability": "+40%-50%"
    }
  },
  "rollout_phases": {
    "phase_1": {
      "name": "基础设施修复",
      "duration": "1-2周",
      "tasks": [
        "修复time模块导入问题",
        "实施数据质量验证",
        "收集训练数据",
        "完成LSTM模型初次训练"
      ]
    },
    "phase_2": {
      "name": "核心算法增强",
      "duration": "2-4周",
      "tasks": [
        "实现LinUCB冷启动优化",
        "集成异步事件引擎",
        "完善监控告警系统"
      ]
    },
    "phase_3": {
      "name": "智能化升级",
      "duration": "1-2月",
      "tasks": [
        "实施市场状态识别优化",
        "添加元学习层",
        "完成回测-实盘偏差校准"
      ]
    }
  }
}
