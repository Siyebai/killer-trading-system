{
  "version": "V5.2",
  "description": "V5.2扩展方向版 - 资金池隔离 + 统计套利 + 贝叶斯优化 + Web仪表板",
  "extensions": {
    "capital_pool_hedging": {
      "enabled": true,
      "description": "资金池隔离与对冲套利",
      "position": "开单和持仓管理环节",
      "features": [
        "独立资金池（永续/现货分离）",
        "资金费率套利",
        "价差套利",
        "市场状态判断套利窗口"
      ],
      "config": {
        "funding_rate_threshold": 0.01,
        "price_spread_threshold": 0.005,
        "position_size_ratio": 0.3,
        "max_hedge_positions": 3,
        "market_regime_integration": true
      },
      "deployment": {
        "perp_pool_id": "perp_pool_001",
        "spot_pool_id": "spot_pool_001",
        "api_keys_separated": true,
        "isolation_required": true
      }
    },
    "pairs_trading": {
      "enabled": true,
      "description": "统计套利（Pairs Trading）",
      "position": "扫描发现和智能决策环节",
      "features": [
        "协整检验（Engle-Granger）",
        "价差Z-score计算",
        "开仓信号：±2σ",
        "平仓信号：0σ",
        "LinUCB权重分配"
      ],
      "config": {
        "significance_level": 0.05,
        "lookback_period": 30,
        "entry_threshold": 2.0,
        "exit_threshold": 0.0,
        "min_observation": 100
      },
      "integration": {
        "linucb_strategy": true,
        "strategy_name": "pairs_trading",
        "default_weight": 0.15
      }
    },
    "adaptive_parameter_optimizer": {
      "enabled": true,
      "description": "自适应参数优化（贝叶斯优化）",
      "position": "复盘总结和优化提升环节",
      "features": [
        "贝叶斯优化超参数",
        "目标函数：夏普比率",
        "每N笔交易自动优化",
        "热加载配置文件",
        "参数组优化（风控/信号/仓位）"
      ],
      "config": {
        "optimization_interval": 100,
        "max_iterations": 50,
        "n_random_starts": 10,
        "objective_function": "sharpe_ratio"
      },
      "parameter_groups": {
        "risk_control": [
          "atr_stop_loss_multiplier",
          "atr_take_profit_multiplier",
          "max_position_size",
          "daily_loss_limit"
        ],
        "signal_generation": [
          "rsi_oversold",
          "rsi_overbought",
          "signal_score_threshold",
          "adx_threshold"
        ],
        "position_management": [
          "kelly_multiplier",
          "trailing_stop_activation",
          "trailing_stop_distance"
        ]
      }
    },
    "web_dashboard": {
      "enabled": true,
      "description": "Web可视化仪表板",
      "position": "运维层监控",
      "features": [
        "实时交易监控",
        "策略权重可视化",
        "资金池状态",
        "数据质量指标",
        "远程控制（紧急停止/手动命令）",
        "LSTM训练损失曲线"
      ],
      "config": {
        "host": "0.0.0.0",
        "port": 8000,
        "cors_enabled": true,
        "refresh_interval": 5000
      },
      "endpoints": {
        "GET /": "HTML仪表板",
        "GET /api/status": "系统状态",
        "GET /api/signals": "最近信号",
        "GET /api/strategy_weights": "策略权重",
        "POST /api/command": "发送远程命令",
        "GET /api/commands/pending": "待处理命令"
      },
      "remote_commands": [
        "START_TRADING",
        "EMERGENCY_STOP",
        "MANUAL_OPEN",
        "MANUAL_CLOSE"
      ]
    }
  },
  "integration_points": {
    "capital_pool_hedging_with_market_regime": {
      "enabled": true,
      "description": "对冲套利与市场状态识别集成",
      "logic": "使用market_regime_optimizer判断套利机会窗口（低波动+稳定资金费率）"
    },
    "pairs_trading_with_linucb": {
      "enabled": true,
      "description": "统计套利与LinUCB集成",
      "logic": "将pairs_trading作为独立策略接入LinUCB策略选择器，动态分配权重"
    },
    "parameter_optimizer_with_config": {
      "enabled": true,
      "description": "参数优化与配置热加载",
      "logic": "优化完成后自动写入配置文件并触发热加载"
    },
    "web_dashboard_with_event_engine": {
      "enabled": true,
      "description": "Web仪表板与事件引擎集成",
      "logic": "通过async_event_engine推送实时信号（开平仓、盈亏、策略权重变化）到Web界面"
    }
  },
  "expected_improvements": {
    "capital_pool_hedging": {
      "risk_isolation": "100%（资金池完全隔离）",
      "arbitrage_profitability": "+5%-15%（资金费率+价差套利）",
      "cross_contamination_prevention": "100%（避免交叉爆仓）"
    },
    "pairs_trading": {
      "strategy_diversification": "+30%（新增统计套利策略）",
      "mean_reversion_profitability": "+10%-20%（价差均值回归）",
      "linucb_optimization": "自动权重分配"
    },
    "adaptive_parameter_optimizer": {
      "parameter_tuning_efficiency": "+80%（自动化替代人工）",
      "performance_improvement": "+15%-25%（基于夏普比率优化）",
      "adaptation_speed": "每100笔交易自动优化"
    },
    "web_dashboard": {
      "monitoring_latency": "<5秒（实时推送）",
      "remote_response_time": "<1秒（命令执行）",
      "visualization_coverage": "100%（所有核心指标）"
    }
  },
  "deployment_checklist": {
    "capital_pool_hedging": [
      "配置永续资金池API密钥",
      "配置现货资金池API密钥",
      "验证资金池隔离",
      "测试对冲开仓",
      "测试对冲平仓"
    ],
    "pairs_trading": [
      "筛选协整交易对（BTC/ETH等）",
      "配置LinUCB权重",
      "测试Z-score信号生成",
      "验证开仓/平仓逻辑"
    ],
    "adaptive_parameter_optimizer": [
      "准备历史交易数据",
      "配置参数空间",
      "测试优化流程",
      "验证配置热加载"
    ],
    "web_dashboard": [
      "安装依赖（fastapi/uvicorn）",
      "配置CORS",
      "测试API端点",
      "验证实时推送",
      "测试远程命令"
    ]
  },
  "dependencies": {
    "capital_pool_hedging": ["sqlite3"],
    "pairs_trading": ["numpy", "pandas", "scipy", "statsmodels"],
    "adaptive_parameter_optimizer": ["numpy", "pandas"],
    "web_dashboard": ["fastapi", "uvicorn", "pydantic"]
  },
  "documentation": {
    "capital_pool_hedging": "见scripts/capital_pool_hedging.py --help",
    "pairs_trading": "见scripts/pairs_trading.py --help",
    "adaptive_parameter_optimizer": "见scripts/adaptive_parameter_optimizer.py --help",
    "web_dashboard": "见scripts/web_dashboard.py --help"
  }
}
