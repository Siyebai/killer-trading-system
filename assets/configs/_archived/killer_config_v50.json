{
  "version": "V5.0_Intelligent",
  "description": "V5.0智能化升级，深度学习动态止盈 + 自适应市场切换",
  "upgrades": {
    "lstm_dynamic_profit": {
      "enabled": true,
      "description": "使用LSTM预测未来N根K线的价格区间，动态调整分批止盈点位"
    },
    "adaptive_regime_switch": {
      "enabled": true,
      "description": "集成regime分类器，趋势市用趋势策略，震荡市自动切换均值回归子策略"
    }
  },
  "lstm_dynamic_profit": {
    "model_path": null,
    "use_pretrained": false,
    "sequence_length": 60,
    "prediction_horizon": 10,
    "lstm_units": 128,
    "dropout_rate": 0.2,
    "learning_rate": 0.001
  },
  "adaptive_regime_switch": {
    "adx_strong_trend": 30,
    "adx_weak_trend": 20,
    "rsi_overbought": 70,
    "rsi_oversold": 30,
    "volatility_high": 0.03,
    "volatility_low": 0.01,
    "min_regime_stability_periods": 3,
    "regime_switch_threshold": 0.7,
    "trend_strategy_weight": 0.7,
    "mean_reversion_weight": 0.3
  },
  "profit_taking": {
    "enabled": true,
    "enable_batch_profit": true,
    "enable_trailing_stop": true,
    "enable_time_exit": true,
    "enable_signal_reversal": true,
    "atr_period": 20,
    "profit_levels": [
      {"atr_multiplier": 2.0, "exit_percent": 0.2},
      {"atr_multiplier": 3.5, "exit_percent": 0.4},
      {"atr_multiplier": 5.5, "exit_percent": 0.4}
    ],
    "trailing_stop": {
      "activation_atr": 3.0,
      "distance_atr": 1.2
    },
    "signal_reversal": {
      "profit_drawdown_threshold": 0.7
    },
    "time_exit": {
      "max_hold_periods": 100
    },
    "dynamic_adjustment": {
      "enabled": true,
      "confidence_high": {
        "atr_multiplier_factor": 1.2,
        "exit_pct_1": 0.3,
        "trailing_activation": 2.5,
        "trailing_distance": 1.0
      },
      "confidence_medium": {
        "atr_multiplier_factor": 1.0,
        "exit_pct_1": 0.2,
        "trailing_activation": 3.0,
        "trailing_distance": 1.2
      },
      "confidence_low": {
        "atr_multiplier_factor": 0.8,
        "exit_pct_1": 0.4,
        "trailing_activation": 2.0,
        "trailing_distance": 1.0
      }
    }
  },
  "stop_loss": {
    "atr_period": 20,
    "atr_multiplier_base": 2.0,
    "dynamic_adjustment": {
      "enabled": true,
      "rules": [
        {"score_min": 0.8, "atr_multiplier": 1.8},
        {"score_min": 0.7, "atr_multiplier": 2.0},
        {"score_min": 0.6, "atr_multiplier": 2.5}
      ]
    }
  },
  "position_management": {
    "base_position_percent": 0.08,
    "max_position_percent": 0.25,
    "kelly_fraction": 0.15,
    "regime_based_adjustment": {
      "strong_trend": 0.25,
      "weak_trend": 0.15,
      "range_bound": 0.15,
      "neutral": 0.0
    }
  },
  "risk_control": {
    "max_drawdown": 0.08,
    "max_daily_loss": 0.02,
    "max_position_pct": 0.25,
    "consecutive_loss_limit": 3
  },
  "hybrid_strategy_framework": {
    "enable_linucb": true,
    "enable_adaptive_weights": true,
    "linucb_alpha": 1.0,
    "min_performance_window": 100,
    "update_frequency": 100
  },
  "metadata": {
    "version_type": "v5.0_intelligent",
    "key_features": [
      "LSTM动态止盈预测",
      "自适应市场切换",
      "动态策略权重调整",
      "智能置信度判断"
    ],
    "expected_improvements": [
      "止盈精准度提升20%-30%",
      "市场适应性提升40%-50%",
      "策略切换延迟降低50%",
      "整体盈亏比提升至1.5-2.0"
    ],
    "created_date": "2026-04-26"
  }
}
