{
  "version": "V5.3",
  "description": "V5.3深度优化版 - 解决三大结构性病灶",
  "diagnosis": {
    "issue_1": {
      "name": "方向性偏好",
      "problem": "189多头（73%胜率）vs 95空头（35.8%胜率）",
      "root_cause": "MA趋势策略权重过高（0.40），过度依赖趋势跟随",
      "solution": "方向平衡过滤器+降低趋势策略权重"
    },
    "issue_2": {
      "name": "止损触发率过高",
      "problem": "46.5%止损退出，平均亏损-$48.31",
      "root_cause": "信号质量阈值50太低，开仓信号过于激进",
      "solution": "信号质量阈值提升至65+自适应止损"
    },
    "issue_3": {
      "name": "夏普比率过低",
      "problem": "夏普比率0.20（优秀系统1.5+）",
      "root_cause": "最大回撤37.73%，收益质量太低",
      "solution": "动态仓位管理+预测性风控"
    }
  },
  "optimizations": {
    "p0_immediate": {
      "priority": "P0",
      "timeline": "1天",
      "items": [
        {
          "name": "提升信号质量阈值",
          "action": "signal_quality_threshold: 0.50 → 0.65",
          "expected_effect": "胜率+7%",
          "implementation": "scripts/seven_layer_system.py"
        },
        {
          "name": "方向平衡过滤器",
          "action": "启用directional_balance_filter，抑制过度偏重某一方向",
          "expected_effect": "空头胜率+15%，多空比例2:1 → 1.2:1",
          "implementation": "scripts/directional_balance_filter.py"
        }
      ]
    },
    "p1_short_term": {
      "priority": "P1",
      "timeline": "1周",
      "items": [
        {
          "name": "自适应止损优化",
          "action": "根据持仓时间动态调整止损距离（2.5x → 2.0x → 1.5x ATR）",
          "expected_effect": "止损触发率46.5% → 35%以下，单笔平均亏损-$48 → -$35",
          "implementation": "scripts/adaptive_stop_loss.py"
        },
        {
          "name": "激活市场状态门控",
          "action": "只在趋势市开仓，震荡市完全不开仓",
          "expected_effect": "止损触发率-15%",
          "implementation": "scripts/market_regime_optimizer.py"
        }
      ]
    },
    "p2_long_term": {
      "priority": "P2",
      "timeline": "1-3月",
      "items": [
        {
          "name": "集成统计套利",
          "action": "将pairs_trading权重从0提升至0.15，与LinUCB集成",
          "expected_effect": "收益率+5%，震荡市稳定收益",
          "implementation": "scripts/pairs_trading.py"
        },
        {
          "name": "贝叶斯参数优化",
          "action": "每50笔交易自动优化参数，目标函数夏普比率",
          "expected_effect": "夏普比率0.20 → 1.2+",
          "implementation": "scripts/adaptive_parameter_optimizer.py"
        },
        {
          "name": "LSTM动态止盈",
          "action": "用LSTM预测未来10根K线，动态调整止盈点位",
          "expected_effect": "止盈触发率48% → 65%，平均盈利+$131 → +$180",
          "implementation": "scripts/lstm_dynamic_profit.py"
        }
      ]
    }
  },
  "seven_layer_system": {
    "enabled": true,
    "layers": [
      {
        "name": "数据聚合层",
        "module": "data_quality_validator.py",
        "function": "数据质量验证 + 多源数据融合",
        "threshold": 0.9
      },
      {
        "name": "市场识别层",
        "module": "market_regime_optimizer.py",
        "function": "自适应市场状态切换",
        "threshold": 0.6
      },
      {
        "name": "策略决策层",
        "module": "hybrid_strategy_framework.py",
        "function": "规则+ML+RL三策略融合",
        "strategies": ["ma_trend", "rsi_mean_revert", "orderflow_break", "pairs_trading"]
      },
      {
        "name": "过滤决策层",
        "module": "signal_scorer.py + directional_balance_filter.py",
        "function": "多时间帧+市场环境+订单流+信号评分+方向平衡",
        "signal_quality_threshold": 0.65,
        "directional_balance_filter": true
      },
      {
        "name": "执行交易层",
        "module": "high_fidelity_execution.py",
        "function": "智能订单路由+动态限价偏移",
        "order_type": "limit_maker",
        "slipage_model": true
      },
      {
        "name": "风控管理层",
        "module": "adaptive_stop_loss.py + predictive_risk_control.py",
        "function": "自适应止损+VaR风险预算+预测性风控",
        "adaptive_stop_loss": true,
        "holding_phase_adjustment": true
      },
      {
        "name": "优化进化层",
        "module": "linucb_cold_start.py + lstm_data_collector.py + adaptive_parameter_optimizer.py",
        "function": "LinUCB冷启动+LSTM数据收集+复盘分析+贝叶斯优化",
        "linucb_enabled": true,
        "lstm_collection_enabled": true,
        "bayesian_optimization_enabled": true
      }
    ]
  },
